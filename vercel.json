{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "functions": {
    "app/api/**": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/discover",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/validator",
      "schedule": "0 */6 * * *"
    }
  ]
}